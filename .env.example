# Shared
LOG_LEVEL=INFO

# News Service
NEWS_SERVICE_HOST=0.0.0.0
NEWS_SERVICE_PORT=8000
DYNAMODB_ENDPOINT=http://localhost:8001
DYNAMODB_REGION=eu-central-1
DYNAMODB_EVENTS_TABLE=news-events
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# RSS Sources (comma-separated URLs)
RSS_FEEDS=https://www.index.hr/rss,https://www.jutarnji.hr/rss,https://www.24sata.hr/rss

# Blockchain
GANACHE_URL=http://localhost:8545
CONTRACT_ADDRESS=
PRIVATE_KEY=

# Auth Service
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8001
DYNAMODB_USERS_TABLE=news-users
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Analytics Service
ANALYTICS_SERVICE_HOST=0.0.0.0
ANALYTICS_SERVICE_PORT=8002

# Frontend
REACT_APP_NEWS_API_URL=http://localhost:8000
REACT_APP_AUTH_API_URL=http://localhost:8001
REACT_APP_ANALYTICS_API_URL=http://localhost:8002
